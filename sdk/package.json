{
  "name": "@flowback/searcher",
  "version": "0.0.3",
  "description": "FlowBack searcher-facing TypeScript SDK — connect to the relay, sign bid commitments, manage escrow, and build Jito-bundle txs.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "rolldown -c --watch",
    "build": "rolldown -c",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "solana",
    "mev",
    "jito",
    "searcher",
    "flowback",
    "auction",
    "backrun",
    "cashback"
  ],
  "author": "FlowBack",
  "license": "MIT",
  "homepage": "https://flowback.fun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flowbackdotfun/flowback.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/flowbackdotfun/flowback/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "rolldown": "1.0.0-rc.17",
    "rolldown-plugin-dts": "^0.23.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.20.0"
  }
}
